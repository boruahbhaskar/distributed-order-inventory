# Java / Maven
target/
*.class
*.jar
*.war
!**/src/main/**/target/
!**/src/test/**/target/

# Spring Boot
*.log
spring.log

# Terraform — NEVER commit state or secrets
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars          # contains DB passwords — keep local only
.terraform.lock.hcl

# VS Code
.vscode/*
!.vscode/settings.json   # DO commit this one (shared team settings)
!.vscode/extensions.json

# macOS
.DS_Store
.AppleDouble

# Docker
.dockerignore

# Secrets / env files
.env
*.pem
*.key

# IDE
*.iml
.idea/
